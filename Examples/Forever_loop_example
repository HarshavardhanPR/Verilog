module forever_example;
  reg clk;
initial begin
    clk = 0;
    forever begin
      #10 clk = ~clk; // Generates a clock with a period of 20 units
    end
  end
  
  initial begin
          #100; $finish;
  end
  
  initial begin
    $dumpfile("dump.vcd");
    $dumpvars(1);
  end
  
  end
endmodule
