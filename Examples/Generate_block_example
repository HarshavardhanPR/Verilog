module my_and_gate (input a, b, output y);
  assign y = a & b;
endmodule

modulegenerate_example (
  input [3:0] A_bus,
  input [3:0] B_bus,
  output [4:0] Y_bus
);
  // genvar is used only during the 'elaboration' phase
  genvar i;
generate
    for (i = 0; i < 4; i = i + 1) begin : gate_gen
      // Instantiate 4 copies of the module automatically
      my_and_gate inst (
        .a(A_bus[i]), 
        .b(B_bus[i]), 
        .y(Y_bus[i])
      );
    end
  endgenerate
endmodule
